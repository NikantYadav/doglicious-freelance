{
    "version": 2,
    "buildCommand": "npm run build",
    "devCommand": "vite --port $PORT",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}