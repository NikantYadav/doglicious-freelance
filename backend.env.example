# --- BACKEND (Server) CONFIGURATION ---

# HubSpot Private App Access Token (pat-na1-...)
HUBSPOT_API_KEY=your_hubspot_pat_token_here

# Gmail SMTP Credentials
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Secure secret for HMAC OTP token signing
OTP_SECRET=your_secret_random_string_here

# Gemini AI API Key (Secured on Backend)
GEMINI_API_KEY=your_gemini_api_key_here

# Port (optional, defaults to 5000)
PORT=5000
