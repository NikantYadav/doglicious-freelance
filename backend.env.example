# --- BACKEND (Server) Configuration ---
# Copy this file to server/.env.backend and fill in your values.

# Kylas API Key
KYLAS_API_KEY=your_kylas_api_key_here

# Gmail SMTP Credentials (used to send OTP emails)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Secure random string for HMAC OTP token signing — change this in production!
OTP_SECRET=your_secret_random_string_here

# AI Provider — provide at least one.
# If GEMINI_API_KEY is set, Gemini is used. Otherwise Claude is used.
CLUADE_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Port (optional, defaults to 5000)
PORT=5000

# --- PayU Payment Gateway ---
# Get Key and Salt from: https://dashboard.payu.in → Developers → API Keys
PAYU_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_merchant_salt
PAYU_ENV=test
# test      → https://test.payu.in/_payment
# production → https://secure.payu.in/_payment

PAYU_AMOUNT=99.00
PAYU_PRODUCT=VetRx Scan - Additional Scans Pack

# Number of free scans allowed before paywall
NUM_FREE_SCAN=1

# Number of paid scans to grant after one successful payment
NUM_SCAN=5

# Full URL of this backend server (used to build PayU surl/furl callbacks)
# Local dev:  http://localhost:5000
# Production: https://your-api.vercel.app
SERVER_URL=http://localhost:5000

# Full URL of the frontend app origin (PayU redirects the user back here after payment)
# The return path is determined dynamically per payment — only set the origin here.
# Local dev:  http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
