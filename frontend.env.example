# --- FRONTEND (Client) Configuration ---
# Copy this file to .env.frontend and fill in your values.
# No API keys here — all secrets live in the backend.

# Backend API URL
# Local dev:  leave empty (Vite proxy forwards /api/* to localhost:5000)
# Production: https://your-api.vercel.app
VITE_API_URL=

# Number of scans unlocked per payment — should mirror NUM_SCAN in backend env
VITE_NUM_SCAN=5
